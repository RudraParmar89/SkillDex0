# Paddle Configuration
# Get these values from your Paddle dashboard: https://dashboard.paddle.com

# Your Paddle Client Token (for frontend)
# Found in: Settings → Credentials → Client Token
VITE_PADDLE_CLIENT_TOKEN=your_paddle_client_token_here

# Paddle API Key (for backend - stored securely on server)
# Found in: Settings → Authentication → API Key
PADDLE_API_KEY=your_paddle_api_key_here

# Paddle Webhook Secret (for validating webhook signatures)
# Found in: Settings → Webhooks → Signing Secret
PADDLE_WEBHOOK_SECRET=your_paddle_webhook_secret_here

# Paddle Product IDs (from your Paddle dashboard)
# Create these in: Products → Your Products
VITE_PADDLE_PRODUCT_FREE=prod_1234567890
VITE_PADDLE_PRODUCT_PRO=prod_0987654321
VITE_PADDLE_PRODUCT_ENTERPRISE=prod_1122334455

# Paddle Price IDs (from your Paddle dashboard)
# Create these in: Products → Prices
VITE_PADDLE_PRICE_PRO_MONTHLY=pri_1234567890
VITE_PADDLE_PRICE_PRO_YEARLY=pri_0987654321
VITE_PADDLE_PRICE_ENTERPRISE_MONTHLY=pri_1122334455
VITE_PADDLE_PRICE_ENTERPRISE_YEARLY=pri_5544332211

# Paddle Environment (sandbox or production)
VITE_PADDLE_ENVIRONMENT=production

# For Sandbox Testing (use these values instead for testing)
# VITE_PADDLE_CLIENT_TOKEN=your_sandbox_client_token
# VITE_PADDLE_ENVIRONMENT=sandbox

# Success & Error URLs (optional, can be set in Checkout config)
VITE_PAYMENT_SUCCESS_URL=http://localhost:5173/payment-success
VITE_PAYMENT_ERROR_URL=http://localhost:5173/pricing
